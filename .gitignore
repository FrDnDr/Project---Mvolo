# ============================================
# Mvolo — .gitignore
# ============================================

# ── Environment & Secrets ──
.env
*.env
secrets/

# ── Python ──
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
.pytest_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# ── Evolution & History ──
.history/
.vscode/
.idea/

# ── Documentation (User Requested) ──
docs/
learning_roadmap.md
LEARNING_ROADMAP.md
project_directory_plan.md

# ── Databases ──
*.duckdb
*.duckdb.wal
*.duckdb.tmp/

# ── dbt (Transformation) ──
transform/target/
transform/dbt_packages/
transform/logs/
profiles.yml
!transform/seeds/*.csv

# ── Docker ──
docker/metabase/metabase.db/
.docker/

# ── Data ──
# Ignore raw data (contains PII), but keep sample data
data/raw/
*.csv
*.json
!data/sample/*.json
!tests/fixtures/*.json
!transform/seeds/*.csv

# ── Logs ──
logs/
*.log

# ── OS Specific ──
.DS_Store
Thumbs.db
Desktop.ini

# ── API Testing ──
api testing/

# ── .ih ──
.ih/

# ── workspace ──
Project - Mvolo.code-workspace

# ── env ──

# visualization
visualization/bol-dashboard/data

# shopify oauth
shopify-oauth/